{
  "compilerOptions": {
    "target": "ES2022", "module": "CommonJS", "lib": ["ES2022"],
    "outDir": "./dist", "rootDir": "./src", "moduleResolution": "node",
    "declaration": true, "strict": true, "esModuleInterop": true, "skipLibCheck": true
  },
  "include": ["src/**/*"], "exclude": ["node_modules", "dist"]
}

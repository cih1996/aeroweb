{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/preload",
    "rootDir": "./preload",
    "module": "CommonJS",
    "target": "ES2022",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": ["preload/**/*"]
}

